# --- Bridge network ---
PORT=3712
HOST=127.0.0.1

# --- Permission flow ---
HOOK_TIMEOUT=300
# Behaviour when a decision can't be reached (timeout or no device connected):
#   deny = block the tool (default)
#   ask  = defer to Claude Code's normal in-terminal permission prompt
HOOK_FALLBACK_BEHAVIOR=deny
# Grace window (seconds) to wait for a phone/watch before giving up on a
# request when no SSE client is connected. Prevents long blocks when the
# watch is unreachable.
NO_CLIENT_GRACE_SECONDS=3

# --- Pairing ---
PAIRING_CODE_EXPIRY=120
PAIRING_CODE_LENGTH=6
PAIR_VERIFY_MAX_ATTEMPTS=5
PAIR_VERIFY_WINDOW=60
# Session token lifetime (seconds). Default: 7 days.
SESSION_TTL=604800
TOKEN_LENGTH=32

# --- SSE ---
SSE_HEARTBEAT=30

# --- Logging ---
LOG_LEVEL=info
# Log file path. Unset -> ~/.claude-watch/bridge.log. Set to "" to disable
# file logging (the launchd daemon does this and captures stdout instead).
# LOG_FILE=

# --- Persistence ---
# Where sessions.json and logs live. Default: ~/.claude-watch
# DATA_DIR=/tmp/claude-watch

# --- (Optional) shared secret for hook endpoints ---
# If set, Claude Code hook requests must send Authorization: Bearer <HOOK_TOKEN>.
# Note: requires Claude Code http hooks to support custom headers.
HOOK_TOKEN=
